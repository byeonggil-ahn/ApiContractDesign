package apicontractdesign.controller;

import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.RequestMapping;
import org.springframework.web.bind.annotation.RequestParam;
import org.springframework.web.bind.annotation.RestController;

import apicontractdesign.service.UserService;

/**
 * Controller 계층
 * - HTTP 요청/응답 담당
 * - 외부 Open API 호출은 Service로 위임
 */
@RestController
@RequestMapping("/api/naver")
public class UserController {

    private final UserService userService;

    public UserController(UserService userService) {
        this.userService = userService;
    }

    /**
     * [프로젝트 2]
     * 네이버 로그인 시작
     * - 네이버 OAuth 인가 URL 반환
     * - 프론트는 이 URL로 리다이렉트만 하면 됨
     */
    @GetMapping("/login")
    public String naverLogin() {
        return userService.naverLogin();
    }

    /**
     * [프로젝트 2]
     * 네이버 OAuth 콜백
     * - 네이버가 redirect_uri로 자동 호출
     * - code만 받아서 다음 단계(Service)로 넘길 준비
     */
    @GetMapping("/callback")
    public String naverCallback(
            @RequestParam String code,
            @RequestParam(required = false) String state
    ) {

        // 지금 단계에서는 계약 확인용으로 code만 반환
        // 다음 단계에서 이 code로 Access Token 요청
        return "naver oauth callback success, code = " + code;
    }
}