package apicontractdesign.service;

import java.io.UnsupportedEncodingException;
import java.net.URLEncoder;

import org.springframework.stereotype.Service;

import apicontractdesign.domain.User;
import apicontractdesign.dto.UserRequestDto;
import apicontractdesign.repository.UserRepository;

/**
 * Service 구현체
 * - 비즈니스 로직 처리
 * - Repository 조합
 */
@Service
public class UserServiceImpl implements UserService {

    private final UserRepository userRepository;

    // 생성자 주입 (기존 그대로)
    public UserServiceImpl(UserRepository userRepository) {
        this.userRepository = userRepository;
    }

    /**
     * [프로젝트 1]
     * 내부 User 생성
     */
    @Override
    public User createUser(UserRequestDto dto) {
        User user = new User(1L, dto.getName());
        return userRepository.save(user);
    }

    /**
     * [프로젝트 2]
     * 네이버 로그인 시작
     * - 외부 Open API 계약
     */
    @Override
    public String naverLogin() {
        try {
            // 네이버 Open API에서 발급받은 Client ID
            String clientId = "AipfQlUUw8jMr4oAQIPi";

            // 네이버 개발자 콘솔에 등록한 콜백 URL
            String callbackUrl = "http://localhost:8080/login/oauth2/code/naver";

            // OAuth 계약 파라미터
            String redirectUri = URLEncoder.encode(callbackUrl, "UTF-8");
            String state = URLEncoder.encode(callbackUrl, "UTF-8");

            // 네이버 OAuth 인가 요청 URL 생성
            return "https://nid.naver.com/oauth2.0/authorize"
                    + "?response_type=code"
                    + "&client_id=" + clientId
                    + "&redirect_uri=" + redirectUri
                    + "&state=" + state;

        } catch (UnsupportedEncodingException e) {
            throw new RuntimeException("네이버 로그인 URL 생성 실패", e);
        }
    }
}