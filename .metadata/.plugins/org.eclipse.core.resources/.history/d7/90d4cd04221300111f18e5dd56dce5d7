openapi: 3.0.3

info:
  title: testapicontact
  description: >
    네이버 로그인 이후 발급된 access token을 사용하여
    회원정보를 조회하는 API 계약 문서
  version: 1.0.0

servers:
  - url: http://localhost:8080
    description: Local server

paths:
  /naver/users/me:
    get:
      summary: 네이버 회원정보 조회
      description: >
        :contentReference[oaicite:0]{index=0} 로그인으로 발급된
        access token을 사용하여 현재 로그인한 사용자의 회원 정보를 조회한다.
        (로그인 / 토큰 발급 단계는 본 API의 범위가 아니다)
      tags:
        - Naver User
      security:
        - bearerAuth: []
      responses:
        "200":
          description: 회원정보 조회 성공
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/NaverUserResponse"
              examples:
                success:
                  value:
                    resultcode: "00"
                    message: success
                    response:
                      id: "32742776"
                      email: openapi@naver.com
                      name: 오픈API
                      nickname: OpenAPI
                      gender: F
                      age: "40-49"
        "401":
          description: 인증 실패 (유효하지 않은 access token)
        "500":
          description: 네이버 서버 오류

components:
  securitySchemes:
    bearerAuth:
      type: http
      scheme: bearer
      bearerFormat: JWT

  schemas:
    NaverUserResponse:
      type: object
      properties:
        resultcode:
          type: string
          example: "00"
        message:
          type: string
          example: success
        response:
          $ref: "#/components/schemas/NaverUser"

    NaverUser:
      type: object
      properties:
        id:
          type: string
          description: 네이버 사용자 고유 ID
          example: "32742776"
        email:
          type: string
          example: openapi@naver.com
        name:
          type: string
          example: 오픈API
        nickname:
          type: string
          example: OpenAPI
        gender:
          type: string
          example: F
        age:
          type: string
          example: "40-49"